#!/usr/bin/env bash
# .githooks/pre-commit — validate SKILL.md front-matter before every commit.
#
# Install: git config core.hooksPath .githooks
#
# Only runs when staged files include a SKILL.md; exits 0 otherwise.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$REPO_ROOT/plugins/leadv2/scripts/leadv2-validate-skills.sh"

# Check if any staged file is a SKILL.md
if ! git diff --cached --name-only | grep -q 'SKILL\.md$'; then
  exit 0
fi

if [[ ! -x "$VALIDATOR" ]]; then
  echo "WARN: validator not found or not executable: $VALIDATOR" >&2
  exit 0
fi

echo "pre-commit: running leadv2-validate-skills.sh ..."
bash "$VALIDATOR"
